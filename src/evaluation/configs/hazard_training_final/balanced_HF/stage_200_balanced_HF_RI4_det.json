    "mission_success": 120,
    "k_progress": 10,
    "hazard_lambda": 10,
    "w_flood": 0.6,
    "w_landslide": 0.4,
    "eta_time": 0.3,
    "step_cost": 0.05,
    "revisit_penalty": 0.1,
    "backtrack_penalty": 0.25,
    "penalty_timeout": -120,
    "penalty_blockage": -120,
    "penalty_incomplete_per_delivery": -20
  },
  "model": {
    "hidden_sizes": [
      128,
      64
    ],
