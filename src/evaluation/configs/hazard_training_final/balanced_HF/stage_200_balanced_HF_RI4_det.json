  "hazard": {
    "rain_levels": {
      "RI1": {
        "speed_mult": 0.94,
        "flood_block_threshold": 1.1,
        "flood_block_prob": 0,
        "landslide_block_threshold": 1.1,
        "landslide_block_prob": 0
      },
      "RI2": {
        "speed_mult": 0.9,
        "flood_block_threshold": 1,
        "flood_block_prob": 1,
        "landslide_block_threshold": 1.1,
        "landslide_block_prob": 0
      },
      "RI3": {
        "speed_mult": 0.85,
        "flood_block_threshold": 0.6,
        "flood_block_prob": 1,
        "landslide_block_threshold": 1.1,
        "landslide_block_prob": 0
      },
      "RI4": {
        "speed_mult": 0.4,
        "flood_block_threshold": 0.6,
        "flood_block_prob": 1,
        "landslide_block_threshold": 1,
        "landslide_block_prob": 1
      },
      "RI5": {
        "speed_mult": 0.2,
        "flood_block_threshold": 0.6,
        "flood_block_prob": 1,
        "landslide_block_threshold": 0.6,
        "landslide_block_prob": 1
      }
    },
    "active_rain_keys": [
      "RI4"
    ],
    "flood_time_weight": 0.5,
    "landslide_time_weight": 0.5,
    "high_risk_flood_threshold": 0.6,
    "high_risk_landslide_threshold": 0.5,
    "max_neighbor_slots": 4,
    "neighbor_feature_dim": 7
  },
  "reward": {
